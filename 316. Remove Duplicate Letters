class Solution {
public:
    string removeDuplicateLetters(string s) {
       vector<int>last(26);
        vector<bool>in(26,false);
        stack<char>st;
        string ans="";
        for(int i=0;i<s.size();i++){
            last[s[i]-'a']=i;
        }
        for(int i=0;i<s.size();i++){
            if(in[s[i]-'a']){
                continue;
            }
            while(!st.empty() && st.top()>s[i] && last[st.top()-'a']>i){
                in[st.top()-'a']=false;
                st.pop();
            }
                st.push(s[i]);
                in[s[i]-'a']=true;
        }
        while(!st.empty()){
            ans+=st.top();
            st.pop();
        }
        reverse(ans.begin(),ans.end());
        return ans;  
    }
};
