class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
        unordered_map<int,int>freq;
        for(int i=0;i<nums.size();i++){
            freq[nums[i]]++;
        }
        int n=nums.size();
        vector<int> result;
         for(auto& x:freq){
            if(x.second>(n/3)){
                result.push_back(x.first);
            }
        }
        return result; 
    }     
};
