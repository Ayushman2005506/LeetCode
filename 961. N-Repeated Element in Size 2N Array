class Solution {
public:
    int repeatedNTimes(vector<int>& nums) {
        int n=nums.size();
        int ans=0;
        unordered_map<int,int>freq;
        for(int i=0;i<n;i++){
            freq[nums[i]]++;
        }
        for(auto x:freq){
            if(x.second==n/2){
                ans=x.first;
            }
        }
        return ans;
    }
};
