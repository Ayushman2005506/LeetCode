class Solution {
public:
    int maxPower(string s) {
        int ans=1;
        int count=1;
        for(int i=0;i<s.size()-1;i++){
            if(s[i]!=s[i+1]){
                count=1;
            }
            else{
                count++;
            }
            ans=max(count,ans);
        }
        return ans;
    }
};
