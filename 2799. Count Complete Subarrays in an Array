class Solution {
public:
    int countCompleteSubarrays(vector<int>& nums) {
        int n=nums.size();
        unordered_set<int> distinct_set(nums.begin(), nums.end());
        int total_distinct=distinct_set.size();
        unordered_map<int, int> freq;
        int left=0;
        int count=0;
        
        for (int right=0;right<n;right++) {
            freq[nums[right]]++;
            while (freq.size()==total_distinct) {
                count+=n-right;
                freq[nums[left]]--;
                if (freq[nums[left]]==0) {
                    freq.erase(nums[left]);
                }
                left++;
            }
        }
        
        return count;
    }
};
