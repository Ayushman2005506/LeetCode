class Solution {
public:
    int findDuplicate(vector<int>& nums) {
        unordered_map<int,int> freq;
        int ans=0;
        for(int i=0;i<nums.size();i++){
            freq[nums[i]]++;
        }
        for(auto x:freq){
            if(x.second!=1){
                ans=x.first;
            }
        }
        return ans;
    }
};
