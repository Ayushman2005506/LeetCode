class Solution {
public:
    int sumOfTheDigitsOfHarshadNumber(int x) {
        int num=x;
        int ans=0;
        while(x>0){
            int digit=x%10;
            ans+=digit;
            x=x/10;
        }
        if(num%ans==0){
            return ans;
        }
        else{
            return -1;
        }
    }
};
