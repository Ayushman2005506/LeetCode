class Solution {
public:
    long long dividePlayers(vector<int>& skill) {
        int n=skill.size();
        long long ans=0;
        sort(skill.begin(),skill.end());
        int target=skill[0]+skill[n-1];
        for(int i=0;i<n/2;i++){
            int current=skill[i]+skill[n-1-i];
            if(current!=target){
                return -1;
            }
            else{
                ans+=(skill[i]*skill[n-1-i]);
            }
        }
        return ans;
    }
};
