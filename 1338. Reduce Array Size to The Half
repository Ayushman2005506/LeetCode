class Solution {
public:
    int minSetSize(vector<int>& arr) {
        int n=arr.size();
        int count=0;
        unordered_map<int,int>freq;
        for(int i=0;i<n;i++){
            freq[arr[i]]++;
        }

        vector<int>frequency;
        for(auto x:freq){
            frequency.push_back(x.second);
        }
        sort(frequency.begin(),frequency.end(),greater<int>());
        int size=0;
        for(auto f:frequency){
            size+=f;
            count++;
            if(size>=n/2){
                break;
            }
        }
        return count;
    }
};
