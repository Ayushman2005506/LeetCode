class Solution {
public:
    int reinitializePermutation(int n) {
        int count=0;
        vector<int>perm;
        for(int i=0;i<n;i++){
            perm.push_back(i);
        }
        vector<int>copy=perm;

        while(true){
            vector<int>ans(n);
            for(int i=0;i<n;i++){
                if(i%2==0){
                    ans[i]=perm[i/2];
                }
                else{
                    ans[i]=perm[n/2+(i-1)/2];
                }
            }
            perm=ans;
            count++;
            if(perm==copy){
                break;
            }
        }
        return count;
    }
};
