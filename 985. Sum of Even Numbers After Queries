class Solution {
public:
    vector<int> sumEvenAfterQueries(vector<int>& nums, vector<vector<int>>& queries) {
        vector<int> ans;
        for(int i=0;i<queries.size();i++){
            nums[queries[i][1]]+=queries[i][0];
            int count=0;
            for(int j=0;j<nums.size();j++){
                if(nums[j]%2==0){
                    count+=nums[j];
                }
            }
            ans.push_back(count);
        }
        return ans;
    }
};
