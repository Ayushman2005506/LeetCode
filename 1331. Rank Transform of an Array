class Solution {
public:
    vector<int> arrayRankTransform(vector<int>& arr) {
        if (arr.empty()) return {};
        vector<int> temp=arr;
        sort(temp.begin(),temp.end());
        int rank=1;
        unordered_map<int,int>ranks;
        ranks[temp[0]]=rank;
        for(int i=1;i<temp.size();i++){
            if(temp[i]!=temp[i-1]){
                ranks[temp[i]]=++rank;
            }
        }
        vector<int>result(arr.size());
        for(int i=0;i<arr.size();i++){
            result[i]=ranks[arr[i]];
        }
        return result;
    }
};
