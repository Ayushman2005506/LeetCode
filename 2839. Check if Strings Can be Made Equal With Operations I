class Solution {
public:
    bool canBeEqual(string s1, string s2) {
        bool equal=false;
        for(int i=0;i<s1.size();i++){
            for(int j=0;j<s1.size();j++){
                if(j-i==2 || i-j==2){
                    swap(s1[i],s1[j]);
                }
                if(s1==s2){
                    equal=true;
                    return equal;
                }
                if(j-i==2){
                    swap(s1[i],s1[j]);
                }
            }
        }
        return equal;
    }
};
