class Solution {
public:
    int matrixSum(vector<vector<int>>& nums) {
        for(int i=0;i<nums.size();i++){
            sort(nums[i].begin(),nums[i].end());
        }
        int score=0;
        int col=nums[0].size();
        for(int i=col-1;i>=0;i--){
            int max=0;
            for(int j=0;j<nums.size();j++){
                if(nums[j][i]>max){
                    max=nums[j][i];
                }
            }
            score+=max;
        }
        return score;
    }
};
