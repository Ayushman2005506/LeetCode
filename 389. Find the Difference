class Solution {
public:
    char findTheDifference(string s, string t) {
        string a=s+t;
        unordered_map<char,int>freq;
        for(int i=0;i<a.length();i++){
            freq[a[i]]++;
        }

        int c=freq.size();
        if(c==1){
            return freq.begin()->first; 
        }

        for(auto x:freq){
            if(x.second%2==1){
                return x.first;
            }
        }
        return 0;
    }
};
